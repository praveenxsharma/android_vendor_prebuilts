android_app_import {
    name: "Dialer",
    apk: "Dialer.apk",
    presigned: true,
    privileged: true,
    system_ext_specific: true,
    overrides: ["Dialer", "GoogleDialer", "com.google.android.dialer"],
}

prebuilt_etc {
    name: "privapp-permissions-dialer.xml",
    src: "privapp-permissions-dialer.xml",
    sub_dir: "permissions",
    system_ext_specific: true,
}
